(common_log) {
	log {
		output stdout
		format console {
			time_format "iso8601"
		}
	}
}

(ocean_web) {
	reverse_proxy ocean-web:3000
	import common_log
}

(blog_web) {
	reverse_proxy blog-web:3000
	import common_log
}

(caddy_auth) {
	basic_auth {
		{$USER} {$PASSWORD_HASH}
	}
}

m31.one, www.m31.one {
	abort
}

ocean-mandela.info, ocean.m31.one {
	import ocean_web
}

ocean.m31.local {
	import ocean_web
	tls internal
}

blog.m31.one {
	import blog_web
}

blog.m31.local {
	import blog_web
	tls internal
}

grafana.m31.one, grafana.m31.local {
	import caddy_auth
	reverse_proxy grafana:3000
}

alloy.m31.one, alloy.m31.local {
	import caddy_auth
	reverse_proxy alloy:12345
}
